# Local proxy target for the OpenAI-compatible model service.
# Do not prefix secrets with VITE_; Vite would expose them to the browser.
OPENAI_COMPAT_BASE_URL="https://coding.dashscope.aliyuncs.com"
OPENAI_COMPAT_API_KEY="YOUR_OPENAI_COMPATIBLE_API_KEY"

# Browser-visible, non-secret settings
VITE_OPENAI_API_BASE="/api/openai"
VITE_OPENAI_MODEL="qwen3.5-plus"
VITE_OPENAI_AVAILABLE_MODELS="qwen3.5-plus,qwen3-max-2026-01-23,qwen3-coder-next,qwen3-coder-plus,glm-5,glm-4.7,kimi-k2.5,MiniMax-M2.5"

APP_URL="MY_APP_URL"
